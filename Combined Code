from sklearn.metrics import roc_auc_score


# Connecting to MySQL and loading data into
conn = sql.connect(
    host="localhost",
    user="root",
    password="",
    database="cap4770"
)

engine = create_engine("mysql+mysqlconnector://root:@localhost/cap4770")

df_csv = pd.read_csv("baseball.csv") # Changed name of train file; same folder as notebook 

df_csv.to_sql("baseball", con=engine, if_exists="replace", index=False)

pd.read_sql("SHOW TABLES", engine) # Confirm dataset loaded in MySQL
pd.read_sql("SELECT COUNT(*) AS total_rows FROM baseball", engine)

# Collection; change to loading from MySQL
baseball = pd.read_csv("baseball.csv") #Renamed train_clean, remove with MySQL working

# Prepocessing

# Drop columns/values
baseball = baseball.dropna(subset=["launch_speed","launch_angle"]).copy()
baseball["bb_type"] = baseball["bb_type"].fillna("Unknown")
for col in baseball.columns:
    if baseball[col].nunique() <= 1:
        baseball = baseball.drop(columns=[col])

cols_to_drop = ["bip_id", "batter_id", "pitcher_id", "batter_name", "pitcher_name"]
baseball = baseball.drop(columns=cols_to_drop, errors="ignore")

X = baseball.drop(columns=["is_home_run"])
y = baseball["is_home_run"]

# One-Hot Encoding (required for SVM)
X = pd.get_dummies(X,drop_first=True)

# Split 70% train, 30% test
X_train, X_test, y_train, y_test = train_test_split(
    X, y, test_size=0.3
)

# Standardization (required for SVM)
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_test_scaled = scaler.transform(X_test)

# Exploration
data = pd.read_csv("baseball.csv") # Replace with MySQL or data already loaded
print("Original Data:\n",data.head())
print(data.info())
print("Original Instances, Features:",data.shape)
print("Original Duplicates:",data.duplicated().sum())
print("Original Nulls:\n",data.isna().sum())

print("\nProcessed Data:")
print(baseball.info()) # Showing modified/processed data 
print("Instances, Features:",baseball.shape)
print("Duplicates:",baseball.duplicated().sum())
print("Nulls:\n",baseball.isna().sum())


# SVM Model
# kernels, class_weight, random_state
svmModel = SVC(kernel='rbf', class_weight='balanced')
svmModel.fit(X_train_scaled, y_train)

# SVM Prediction
y_pred = svmModel.predict(X_test_scaled)

# SVM Confusion Matrix
conf_matrix = confusion_matrix(y_test, y_pred)
print("SVM Confusion Matrix:\n",conf_matrix)

# SVM Accuracy
print("\nSVM Accuracy:",accuracy_score(y_test, y_pred))

# SVM Classification
print("SVM Report:\n",classification_report(y_test,y_pred))

# SVM ROC and AUC
y_scores = svmModel.decision_function(X_test_scaled)
fpr, tpr, _ = roc_curve(y_test, y_scores)
roc_auc = auc(fpr, tpr)

#SVM ROC/AUC Plot
plt.plot(fpr, tpr, label=f"AUC = {roc_auc:.2f}")
plt.plot([0,1], [0,1], '--')
plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.title("ROC Curve (SVM)")
plt.legend()
plt.show()

# SVM Cross Validation
# cv, 
CVscores = cross_val_score(svmModel, X_train_scaled, y_train, cv=5)

print("SVM CV Scores:", CVscores)
print("SVM CV Mean:", CVscores.mean())


# Logistic Regression Model
logModel= LogisticRegression(penalty=None, max_iter=5000, class_weight='balanced')
logModel.fit(X_train_scaled, np.ravel(y_train))

features= X.columns
coef= logModel.coef_[0]

importance= pd.DataFrame({
    'feature': features,
    'coef': coef
        }).sort_values(by='coef', ascending=False)

importance.head(10)
importance.tail(10)

log_pred= logModel.predict(X_test_scaled)
log_prob= logModel.predict_proba(X_test_scaled)[:,1]

print("LR model \n", confusion_matrix(np.ravel(y_test), log_pred))
print("LR model accuracy:", accuracy_score(np.ravel(y_test), log_pred))
print("LR model precision:", precision_score(np.ravel(y_test), log_pred))
print("LR model recall:", recall_score(np.ravel(y_test), log_pred))
print("LR F1 Score:", f1_score(y_test, log_pred))
print("LR ROC AUC:", roc_auc_score(y_test, log_prob))

fpr, tpr, _ = roc_curve(y_test, log_prob)

plt.plot(fpr, tpr)
plt.plot([0,1],[0,1],'--')
plt.title("ROC Curve - Logistic Regression (Balanced)")
plt.xlabel("False Positive Rate")
plt.ylabel("True Positive Rate")
plt.show()

cv_scores = cross_val_score(
    logModel,
    X_train_scaled,
    y_train,
    cv=5,
    scoring='roc_auc'
)

print("Logistic Regression CV AUC scores:", cv_scores)
print("Logistic Regression Mean CV AUC:", cv_scores.mean())

# LR-Ridge Model
ridge_model = LogisticRegression(penalty='l2', max_iter=5000)
ridge_model.fit(X_train_scaled, y_train)
ridge_pred= ridge_model.predict(X_test_scaled)
ridge_prob= ridge_model.predict_proba(X_test_scaled)[:,1]

print("RLR model \n", confusion_matrix(np.ravel(y_test), ridge_pred))
print("RLR model accuracy:", accuracy_score(np.ravel(y_test), ridge_pred))
print("RLR model precision:", precision_score(np.ravel(y_test), ridge_pred))
print("RLR model recall:", recall_score(np.ravel(y_test), ridge_pred))
print("RLR F1 Score:", f1_score(y_test, ridge_pred))
print("RLR ROC AUC:", roc_auc_score(y_test, ridge_prob))

# LR-LASSO Model
lasso_model = LogisticRegression(penalty='l2',solver='liblinear', max_iter=5000)
lasso_model.fit(X_train_scaled, y_train)
